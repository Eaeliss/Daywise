# Supabase — get from https://supabase.com/dashboard/project/_/settings/api
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Sentry — get from https://sentry.io/settings/<org>/projects/<project>/keys/
SENTRY_DSN=

# EAS — get from https://expo.dev/accounts/<username>/projects/<project>
EAS_PROJECT_ID=

# Plaid — get from https://dashboard.plaid.com/developers/keys
PLAID_CLIENT_ID=
PLAID_SECRET=

# Google Cloud Vision — get from https://console.cloud.google.com/apis/credentials
GOOGLE_CLOUD_VISION_API_KEY=
